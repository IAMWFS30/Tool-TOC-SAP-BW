# ============================================
# SAP BW Transport Manager — Environment Config
# ============================================
# Copy this file to .env and fill in your values

# SAP BW DEV (Source System)
SAP_DEV_HOST=sapbwdev.yourcompany.com
SAP_DEV_PORT=8000
SAP_DEV_USER=YOUR_SAP_USER
SAP_DEV_PASS=YOUR_SAP_PASSWORD
SAP_DEV_CLIENT=100
SAP_DEV_PROTOCOL=https

# SAP BW QA / MBQ (Target System)
SAP_QA_HOST=sapbwqa.yourcompany.com
SAP_QA_PORT=8000
SAP_QA_USER=YOUR_SAP_USER
SAP_QA_PASS=YOUR_SAP_PASSWORD
SAP_QA_CLIENT=200
SAP_QA_PROTOCOL=https

# Server Config
PORT=3000
CORS_ORIGIN=*
